<Window x:Class="_1125.View.MyOrdersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Мои заказы" 
        Background="#F5F5F5"
        Height="700" Width="1100" 
        MinWidth="700" MinHeight="500">
   
    <Grid >
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ListBox 
            Background="#F5F5F5"
            Grid.Column="0"
                 ItemsSource="{Binding Orders}"
                 SelectedItem="{Binding SelectedOrder}"
                 BorderThickness="0"
                 Margin="0,0,10,0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#6EA7B5" BorderThickness="2" CornerRadius="8" Padding="10" Margin="5">
                        <StackPanel>
                            <TextBlock Text="Заказ №" Foreground="#242527"/>
                            <TextBlock Text="{Binding Id}" FontWeight="Bold" FontSize="16"/>
                            <TextBlock Text="{Binding Status}" Foreground="#242527" Margin="0,5,0,0"/>
                         </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>


        <ScrollViewer Grid.Column="1" Grid.ColumnSpan="2"  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <TextBlock Text="Детали заказа" FontSize="25" FontWeight="Bold" Foreground="#FF6100" FontFamily="Times New Roman" Margin="0,0,0,10"/>

                <TextBlock Text="Статус:" FontWeight="Bold" Foreground="#242527" FontFamily="Times New Roman" FontSize="20"/>
                <TextBlock Text="{Binding SelectedOrder.Status}" Margin="0,0,0,10" FontSize="20"/>

                <TextBlock Text="Телефон:" FontWeight="Bold" Foreground="#242527" FontFamily="Times New Roman" FontSize="20"/>
                <TextBlock Text="{Binding SelectedOrder.Phone}" Margin="0,0,0,10" FontSize="20" />

                <TextBlock Text="Адрес доставки:" FontWeight="Bold" Foreground="#242527" FontFamily="Times New Roman" FontSize="20"/>
                    <TextBlock Text="{Binding SelectedOrder.Address}" TextWrapping="Wrap" Margin="0,0,0,15" FontSize="20"/>

                <TextBlock Text="Дата доставки:" FontWeight="Bold" Foreground="#242527" FontFamily="Times New Roman" FontSize="20"/>
                    <TextBlock  TextWrapping="Wrap" Margin="0,0,0,0" FontSize="20"/>

                <StackPanel  Grid.Column="1">
                    <TextBlock Text="Данные карты:" FontWeight="Bold" Foreground="#242527" FontFamily="Times New Roman" FontSize="20"/>
              
                    <TextBox TextWrapping="Wrap" Margin="0,0,0,15" FontSize="20" Width="315" HorizontalAlignment="Left"/>
                    <StackPanel  Orientation="Horizontal" HorizontalAlignment="Left" >
                        <TextBox TextWrapping="Wrap" VerticalAlignment="Center" Text="" Margin="0,0,25,15" FontSize="20" Width="225" />
                        <TextBox  TextWrapping="Wrap" Margin="0,0,0,15" FontSize="20"  Width="65"/>
                    </StackPanel>
                    <TextBox  TextWrapping="Wrap" Margin="0,0,0,15" FontSize="20" Width="315" HorizontalAlignment="Left"/>
                </StackPanel>


                
               
                <TextBlock Text="Состав заказа:" FontWeight="Bold" Foreground="#242527" FontFamily="Times New Roman" Margin="0,10,0,5" FontSize="20"/>

                <ItemsControl ItemsSource="{Binding SelectedOrder.Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#FFA4A4A4" BorderThickness="2" CornerRadius="8" Padding="10" Margin="5" Background="WhiteSmoke">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Image Grid.Column="0" Width="110" Height="110"  Source="{Binding ProductImage}" Margin="0,0,10,0" Stretch="Uniform"/>

                                    <TextBlock Grid.Column="1" Text="{Binding ProductName}" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" TextWrapping="Wrap"/>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Stretch" HorizontalAlignment="Center" >
                                        <Button 
       Content="Оставить отзыв на товар"
       FontFamily="Times New Roman"
       Width="190"
       Height="35"
       Background="#E9E9E9"
       Foreground="#242527"
       FontSize="16"
       HorizontalContentAlignment="Center"
       VerticalContentAlignment="Center"
       Margin="5" >
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border CornerRadius="20" Background="{TemplateBinding Background}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>

                                        <Button 
                                        Content="Оставить отзыв на приложение"
                                        FontFamily="Times New Roman"
                                        Width="230"
                                        Height="35"
                                        Background="#E9E9E9"
                                        Foreground="#242527"
                                        FontSize="16"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        Margin="5" >
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border CornerRadius="20" Background="{TemplateBinding Background}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10,0,0,0">
                                        <TextBlock Text="Кол-во" FontSize="12" HorizontalAlignment="Center" Foreground="#242527"/>
                                        <TextBlock Text="{Binding Quantity}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#242527"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
        <StackPanel  Grid.Column="2" VerticalAlignment="Center" Margin="0,45,0,0" >
            <TextBlock Text="ФИО:" FontWeight="Bold" Foreground="#242527" FontFamily="Times New Roman" FontSize="20"/>
            <TextBox  TextWrapping="Wrap" Margin="0,0,0,15" FontSize="20"/>
            <TextBox  TextWrapping="Wrap" Margin="0,0,0,10" FontSize="20"/>
            <TextBox  TextWrapping="Wrap" Margin="0,0,0,0" FontSize="20"/>
            <Button 
                HorizontalAlignment="Right"
                Content="Назад"
                FontFamily="Times New Roman"
                Width="150"
                Height="40"
                Background="#242527"
                Foreground="#FFFFFF"
                FontSize="16"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Margin="5" >
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="20" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
       
    </Grid>
       
</Window>
