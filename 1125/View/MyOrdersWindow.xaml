<Window x:Class="_1125.View.MyOrdersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Мои заказы"
        Height="600" Width="1000" MinWidth="700" MinHeight="500">
    <Border BorderBrush="#2027BC" BorderThickness="15">
    <Grid Margin="10" >
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ListBox Grid.Column="0"
                 ItemsSource="{Binding Orders}"
                 SelectedItem="{Binding SelectedOrder}"
                 BorderThickness="0"
                 Margin="0,0,10,0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#FFA4A4A4" BorderThickness="2" CornerRadius="8" Padding="10" Margin="5">
                        <StackPanel>
                            <TextBlock Text="Заказ №" Foreground="#2027BC"/>
                            <TextBlock Text="{Binding Id}" FontWeight="Bold" FontSize="16"/>
                            <TextBlock Text="{Binding Status}" Foreground="DarkSlateGray" Margin="0,5,0,0"/>
                         </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

   
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <TextBlock Text="Детали заказа" FontSize="25" FontWeight="Bold" Foreground="#2027BC" Margin="0,0,0,10"/>

                    <TextBlock Text="Статус:" FontWeight="Bold" Foreground="#2027BC" FontSize="20"/>
                <TextBlock Text="{Binding SelectedOrder.Status}" Margin="0,0,0,10" FontSize="20"/>

                    <TextBlock Text="Телефон:" FontWeight="Bold" Foreground="#2027BC" FontSize="20"/>
                <TextBlock Text="{Binding SelectedOrder.Phone}" Margin="0,0,0,10" FontSize="20" />

                    <TextBlock Text="Адрес доставки:" FontWeight="Bold" Foreground="#2027BC" FontSize="20"/>
                    <TextBlock Text="{Binding SelectedOrder.Address}" TextWrapping="Wrap" Margin="0,0,0,15" FontSize="20"/>

                    <TextBlock Text="Дата доставки:" FontWeight="Bold" Foreground="#2027BC" FontSize="20"/>
                    <TextBlock Text="{Binding SelectedOrder.DeliveryDateStr}" TextWrapping="Wrap" Margin="0,0,0,15" FontSize="20"/>



                    <TextBlock Text="Состав заказа:" FontWeight="Bold" Foreground="#2027BC" Margin="0,10,0,5" FontSize="20"/>

                <ItemsControl ItemsSource="{Binding SelectedOrder.Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#FFA4A4A4" BorderThickness="2" CornerRadius="8" Padding="10" Margin="5" Background="WhiteSmoke">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Image Grid.Column="0" Width="110" Height="110"  Source="{Binding ProductImage}" Margin="0,0,10,0" Stretch="Uniform"/>

                                    <TextBlock Grid.Column="1" Text="{Binding ProductName}" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" TextWrapping="Wrap"/>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10,0,0,0">
                                        <TextBlock Text="Кол-во" FontSize="12" HorizontalAlignment="Center" Foreground="Gray"/>
                                        <TextBlock Text="{Binding Quantity}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#2027BC"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
        </Border>
</Window>
