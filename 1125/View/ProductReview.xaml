<Window x:Class="_1125.View.ProductReview"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_1125.View"
        mc:Ignorable="d"
          Background="#F5F5F5" 
        Title="ProductReview" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition/>
            <RowDefinition Height="120"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>

        <Button Command="{Binding UploadImageCommand}" Grid.Column="0" Grid.Row="2" 
        Content="Изменить фото 1"
        FontFamily="Times New Roman"
        Margin="0,10"
        Width="150"
        Height ="20"
        Padding="5"
        Background="#FF6100"
        Foreground="White"
        FontSize="14">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border CornerRadius="10"
                    Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <TextBlock Text="Отзыв о товаре" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
           FontSize="22"
           Foreground="#FF6100"
           HorizontalAlignment="Center"
           Margin="0,9"/>

        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Vertical" >
            <TextBlock Text="Имя:" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Left"
             FontSize="17"
             Foreground="#242527"
             Margin="0,10"/>
            <TextBox/>
        </StackPanel>

        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Vertical" >
            <TextBlock Text="Отзыв:" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Left"
      FontSize="17"
      Foreground="#242527"
      Margin="0,9"/>
            <TextBox Height="78"/>
        </StackPanel>

        <TextBlock Text="Оценка:" Grid.Row="3" Grid.Column="1"  HorizontalAlignment="Left"
FontSize="17"
Foreground="#242527"/>
        <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" >
            <Button Content="–" FontSize="13" Width="30"  BorderBrush="Transparent" Background="#F5F5F5"/>
        <TextBlock Width="25"  TextAlignment="Center"  Background="#FFA4A4A4" VerticalAlignment="Center" FontSize="16"/>
            <Button Content="+" FontSize="13" Width="30"  BorderBrush="Transparent" Background="#F5F5F5"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Column="1" Grid.Row="5" VerticalAlignment="Bottom" HorizontalAlignment="Right" >
            <Button FontFamily="Times New Roman"  Margin="0,0,15,10"
BorderThickness="0" 
Content="Назад" 
Grid.Row="1" Grid.Column="1" 
Width="100" Height="25" 
 
Background="#242527" 
Foreground="White"
FontSize="14">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border 
        Background="{TemplateBinding Background}"
        BorderBrush="{TemplateBinding BorderBrush}"
        BorderThickness="{TemplateBinding BorderThickness}"
        CornerRadius="12">
                            <ContentPresenter 
            HorizontalAlignment="Center" 
            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button FontFamily="Times New Roman" Command="{Binding Cancel}"  Margin="0,0,15,10"
BorderThickness="0" 
Content="Добавить" 
Grid.Row="1" Grid.Column="0" 
Width="100" Height="25" 

Background="#6EA7B5" 
Foreground="White"
FontSize="14">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border 
        Background="{TemplateBinding Background}"
        BorderBrush="{TemplateBinding BorderBrush}"
        BorderThickness="{TemplateBinding BorderThickness}"
        CornerRadius="12">
                            <ContentPresenter 
            HorizontalAlignment="Center" 
            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
