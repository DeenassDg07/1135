<Window x:Class="_1125.View.Window1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_1125.View"
        mc:Ignorable="d"
        Title="Window1" Height="200" Width="700">
  
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="125"/>
                <ColumnDefinition Width="550"/>
            </Grid.ColumnDefinitions>
            <Image  Grid.Column="0" Height="180" Width="125" Stretch="Uniform" />
            <StackPanel Grid.Column="1">
                <StackPanel Orientation="Horizontal">
                    <Label Content="Имя:" FontSize="13" Foreground="#242527"/>
                    <TextBlock Width="320" Height="20" Text="{Binding Name}" Margin="0,0,100,0" />
                    <Label Content="Оценка:" FontSize="13" Foreground="#242527"  />
                    <TextBlock Width="20" Height="20" />
                </StackPanel>
                <Border CornerRadius="10" BorderThickness="1" BorderBrush="#FFA4A4A4" Background="#FFA4A4A4">
                    <TextBlock Text="{Binding Description}" FontSize="13" Height="125" TextWrapping="Wrap"/>
                </Border>
            </StackPanel>
        </Grid>

</Window>
