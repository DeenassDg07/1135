<Window x:Class="_1125.View.BasketWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_1125.View"
        mc:Ignorable="d"
        Background="#F5F5F5" 
        Title="BasketWindow" Height="650" Width="800" MinWidth="600" MinHeight="400">
   
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

          
            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ListBox ItemsSource="{Binding CartItems}" 
         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
         HorizontalContentAlignment="Stretch" 
         BorderThickness="0"
         Name="CartListBox">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#FFA4A4A4" BorderThickness="3" CornerRadius="10" Padding="10" Margin="5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Image Height="125" Width="125" Source="{Binding Product.ImageBitmap}" />

                                    <StackPanel Grid.Column="1" Margin="10,0" Orientation="Vertical" MaxWidth="400">
                                        <StackPanel Orientation="Horizontal">
                                            <Label Content="Название:" FontSize="13" Foreground="#2027BC"/>
                                            <TextBlock Width="320" Height="20" Text="{Binding Product.Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <Border CornerRadius="10" BorderThickness="1" BorderBrush="#FFA4A4A4" Background="#FFA4A4A4" Padding="5" Margin="0,5" MaxWidth="400" MaxHeight="126" >
                                            <TextBlock Text="{Binding Product.Description}" FontSize="13" TextWrapping="Wrap" TextTrimming="WordEllipsis" />
                                        </Border>
                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                            <Label Content="Осталось:" FontSize="13" Foreground="#2027BC"/>
                                            <TextBlock Text="{Binding Product.Availability}" FontSize="13" VerticalAlignment="Center"/>
                                            <Label Content="Шт"   Foreground="#2027BC" FontSize="13" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Bottom" Margin="10,0,0,10">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5" VerticalAlignment="Center">
                                            <Label Content="Цена:" FontSize="20" Foreground="#2027BC"/>
                                            <Border BorderBrush="#2027BC" BorderThickness="2" Margin="5,0" Padding="5,0"  Width="100" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Product.Price, StringFormat=N2}" TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10" HorizontalAlignment="Center">
                                            <Button Content="–" FontSize="15" Width="30" Margin="5,0"
                                    Command="{Binding DataContext.DecreaseCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                    CommandParameter="{Binding}" />
                                            <TextBlock Width="40" Text="{Binding Quantity}" TextAlignment="Center" Background="#FFA4A4A4" VerticalAlignment="Center" FontSize="16"/>
                                            <Button Content="+" FontSize="15" Width="30" Margin="5,0"
                                    Command="{Binding DataContext.IncreaseCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                    CommandParameter="{Binding}" />
                                        </StackPanel>

                                        <Button FontSize="15" Height="35" Background="#FF2027BC" Foreground="White" Content="Удалить"
                                Command="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                CommandParameter="{Binding}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="20">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </ScrollViewer>

            <Grid Grid.Row="1" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Row="1" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" MinWidth="330" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                <StackPanel Grid.Column="0"  Orientation="Horizontal" VerticalAlignment="Top" Height="36">
                    <Label Content="Общая сумма:" FontSize="20" Foreground="#FF6100" VerticalAlignment="Center"/>
                    <TextBlock FontSize="20" FontWeight="Bold" Foreground="#FF6100" Text="{Binding TotalPrice}" VerticalAlignment="Center" Margin="5,0"/>
                    <Label Content="руб." FontSize="20" Foreground="#FF6100" VerticalAlignment="Center"/>
                    </StackPanel>

                <StackPanel Grid.Column="0"  Orientation="Vertical" VerticalAlignment="Stretch" Height="100">
                    <Label Content="Данные карты:" FontSize="20" Foreground="#000000" VerticalAlignment="Center"/>
                    <TextBox/>
                    <TextBox/>
                    <TextBox/>
                    <TextBox/>
                </StackPanel>




                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Right" Margin="0,19,0,0" Width="327">
                        <Label Content="Телефон:" Foreground="Black"/>
                    <TextBox HorizontalAlignment="Left" Text="{Binding Tel, UpdateSourceTrigger=PropertyChanged}" Width="200" Margin="0,0,0,5"/>
                        <Label Content="Адрес доставки:" Foreground="Black"/>
                    <TextBox HorizontalAlignment="Left" Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" Width="200"/>
                        <Label Content="Фамилия:" Foreground="Black"/>
                    <TextBox HorizontalAlignment="Left"  Width="200"/>
                        <Label Content="Имя:" Foreground="Black"/>
                    <TextBox HorizontalAlignment="Left"  Width="200"/>
                        <Label Content="Очество:" Foreground="Black"/>
                    <TextBox HorizontalAlignment="Left"  Width="200"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Height="40" Margin="4,5,0,0" Width="315">
                    <Button Command="{Binding Back2}" BorderThickness="0" VerticalAlignment="Bottom" Content="Назад" Foreground="White" Background="#242527" FontSize="20" Width="130" Height="40" Margin="0 0 15 0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border 
     Background="{TemplateBinding Background}"
     BorderBrush="{TemplateBinding BorderBrush}"
     BorderThickness="{TemplateBinding BorderThickness}"
     CornerRadius="20">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Command="{Binding Order}" BorderThickness="0" VerticalAlignment="Bottom" Content="Оформить заказ" Foreground="White" Background="#FF6100" FontSize="20" Width="170" Height="40" Click="Button_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border 
     Background="{TemplateBinding Background}"
     BorderBrush="{TemplateBinding BorderBrush}"
     BorderThickness="{TemplateBinding BorderThickness}"
     CornerRadius="20">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

            </Grid>


            </Grid>
        </Grid>
   
</Window>
