<Window x:Class="_1125.View.EditingOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="_1125.ViewModel"
        mc:Ignorable="d"
        Title="Редактирование заказа"
        Height="520"
        Width="736"
        Background="#F5F5F5" 
        WindowStartupLocation="CenterScreen">

    
        <Grid Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

      
            <TextBlock Text="Редактирование заказа"
                       FontSize="22"
                       Foreground="#FF6100"
                       HorizontalAlignment="Center"
                       Margin="0,10" />

          
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <Grid Margin="10,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                   
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,0,20,0">
                        <StackPanel Margin="0,0,20,0">
                        <Label Content="ID заказа:" Foreground="#242527" FontSize="16" FontFamily="Times New Roman" />
                            <ComboBox Width="80"
                                      ItemsSource="{Binding OrderIds}"
                                      SelectedItem="{Binding SelectedOrderId, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel>
                        <Label Content="Статус:" FontFamily="Times New Roman" Foreground="#242527" FontSize="16" />
                            <ComboBox Width="212"
          ItemsSource="{Binding Statuses}"
          SelectedItem="{Binding SelectedEditableOrder.Status, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        </StackPanel>
                    </StackPanel>

                  
                    <StackPanel Grid.Column="1" VerticalAlignment="Top">
                    <Label Content="Адрес:" FontFamily="Times New Roman" Foreground="#242527" FontSize="16" Width="297" />
                        <TextBox Width="300"
                                 Text="{Binding SelectedEditableOrder.Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="14"
                                 Margin="0,0,0,10" />

                    <Label Content="Телефон:" FontFamily="Times New Roman" Foreground="#242527" FontSize="16" Width="297" />
                        <TextBox Width="300"
                                 Text="{Binding SelectedEditableOrder.Phone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="14"
                                 Margin="0,0,0,10" />

                    <Label Content="ФИО:" FontFamily="Times New Roman" Foreground="#242527" FontSize="16" Width="297" />
                    <TextBox Width="300"
              FontSize="14"
              Margin="0,0,0,10" />

                    <Label Content="Данные карты:" FontFamily="Times New Roman" FontSize="16" Foreground="#000000" VerticalAlignment="Center" Width="297" />
                    <TextBox   Margin="0,0,0,8" Width="300" HorizontalAlignment="Center "  FontSize="14"/>
                        <StackPanel Grid.Column="0"  Orientation="Horizontal" HorizontalAlignment="Center"  Width="300" Height="25" >
                        <TextBox Text="" Margin="0,0,25,7" Width="235"  FontSize="14"/>
                        <PasswordBox PasswordChar="*"  Margin="0,0,0,7" Width="40"  FontSize="14" />
                        </StackPanel>
                    <TextBox Text="" Margin="0,0,0,8" Width="300" HorizontalAlignment="Center"  FontSize="14"/>


                    <Label FontFamily="Times New Roman" Content="Дата доставки:" Foreground="#242527" FontSize="16" Width="134" />
                        <DatePicker Width="140"
                                    SelectedDate="{Binding SelectedEditableOrder.DeliveryDate, Mode=TwoWay}"
                                    FontSize="14" />
                    </StackPanel>
                </Grid>
            </ScrollViewer>

          
            <StackPanel Grid.Row="2"  Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
                <Button Command="{Binding SaveCommand}"
                        Content="Сохранить"
                        FontFamily="Times New Roman"
                        Width="120"
                        Height="35"
                        Background="#FF6100"
                        Foreground="White"
                        FontSize="16"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Margin="5" >
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                        <Border CornerRadius="20" Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Command="{Binding CancelCommand}"
                        Content="Отмена"
                        FontFamily="Times New Roman"
                        Width="120"
                        Height="35"
                        Background="#6EA7B5"
                        Foreground="White"
                        FontSize="16"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Margin="5">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="20" Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
  
</Window>
