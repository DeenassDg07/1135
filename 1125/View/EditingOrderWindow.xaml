<Window x:Class="_1125.View.EditingOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="_1125.ViewModel"
        mc:Ignorable="d"
        Title="Редактирование заказа"
        Height="409"
        Width="736"
        WindowStartupLocation="CenterScreen">

    <Border BorderBrush="#2027BC" BorderThickness="15">
        <Grid Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

      
            <TextBlock Text="Редактирование заказа"
                       FontSize="22"
                       Foreground="#2027BC"
                       HorizontalAlignment="Center"
                       Margin="0,10" />

          
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <Grid Margin="10,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                   
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,0,20,0">
                        <StackPanel Margin="0,0,20,0">
                            <Label Content="ID заказа:" Foreground="#2027BC" FontSize="16" />
                            <ComboBox Width="80"
                                      ItemsSource="{Binding OrderIds}"
                                      SelectedItem="{Binding SelectedOrderId, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel>
                            <Label Content="Статус:" Foreground="#2027BC" FontSize="16" />
                            <ComboBox Width="212"
          ItemsSource="{Binding Statuses}"
          SelectedItem="{Binding SelectedEditableOrder.Status, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        </StackPanel>
                    </StackPanel>

                  
                    <StackPanel Grid.Column="1" VerticalAlignment="Top">
                        <Label Content="Адрес:" Foreground="#2027BC" FontSize="16" Width="311" />
                        <TextBox Width="300"
                                 Text="{Binding SelectedEditableOrder.Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="14"
                                 Margin="0,0,0,15" />

                        <Label Content="Телефон:" Foreground="#2027BC" FontSize="16" Width="297" />
                        <TextBox Width="300"
                                 Text="{Binding SelectedEditableOrder.Phone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="14"
                                 Margin="0,0,0,15" />

                        <Label Content="Дата доставки:" Foreground="#2027BC" FontSize="16" Width="134" />
                        <DatePicker Width="140"
                                    SelectedDate="{Binding SelectedEditableOrder.DeliveryDate, Mode=TwoWay}"
                                    FontSize="14" />
                    </StackPanel>
                </Grid>
            </ScrollViewer>

          
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
                <Button Command="{Binding SaveCommand}"
                        Content="Сохранить"
                        Width="120"
                        Height="35"
                        Background="#FF2027BC"
                        Foreground="White"
                        FontSize="16"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Margin="5">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="8" Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Command="{Binding CancelCommand}"
                        Content="Отмена"
                        Width="120"
                        Height="35"
                        Background="#FFA0A0A0"
                        Foreground="White"
                        FontSize="16"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Margin="5">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="8" Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
